# Template for Phase 12 — copy to: .env.example (commit this; never commit a real .env)

# HTTP listen address
SERVER_ADDR=:8080

# Environment: dev | staging | production (production enforces a strong JWT_SECRET)
APP_ENV=dev

# Postgres DSN (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cpdhub?sslmode=disable

# JWT signing secret (REQUIRED in production — set a long random value)
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated allowed CORS origins. Use the explicit web origin(s) in prod; "*" only in dev.
CORS_ORIGINS=*

# Apply migrations automatically on boot (single-instance only). Prefer a release step in prod.
AUTO_MIGRATE=true
